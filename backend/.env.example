# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# Supabase connection string (production) or local PostgreSQL (development)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# OpenAI — optional, only required for AI explanation feature
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Production frontend URL — set to your Vercel deployment URL after deploying
# Render: add this as an environment variable once you have the Vercel URL
FRONTEND_URL=https://your-app.vercel.app

# Alternative: comma-separated list of allowed origins (use instead of or in addition to FRONTEND_URL)
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com